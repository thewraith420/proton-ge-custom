From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Bob <bob@localhost>
Subject: [PATCH] winegstreamer: Fix surfaceless EGL display for older gstreamer

GST_GL_DISPLAY_TYPE_EGL_SURFACELESS was added in gstreamer 1.24.
Fall back to GST_GL_DISPLAY_TYPE_EGL_DEVICE for older versions.
---
 dlls/winegstreamer/unixlib.c | 6 +++++-
 1 file changed, 5 insertions(+), 1 deletion(-)

diff --git a/dlls/winegstreamer/unixlib.c b/dlls/winegstreamer/unixlib.c
index 1111111111..2222222222 100644
--- a/dlls/winegstreamer/unixlib.c
+++ b/dlls/winegstreamer/unixlib.c
@@ -324,7 +324,11 @@ static void init_gstreamer_once(void)
     if ((e = getenv("GST_GL_DISPLAY")) && strlen(e) > 0)
         gl_display = gst_gl_display_new();
     else
+#ifdef GST_GL_DISPLAY_TYPE_EGL_SURFACELESS
         gl_display = gst_gl_display_new_with_type(GST_GL_DISPLAY_TYPE_EGL_SURFACELESS);
+#else
+        gl_display = gst_gl_display_new_with_type(GST_GL_DISPLAY_TYPE_EGL_DEVICE);
+#endif

     if (!gl_display)
         GST_ERROR("Failed to create OpenGL display");
--
2.39.2

