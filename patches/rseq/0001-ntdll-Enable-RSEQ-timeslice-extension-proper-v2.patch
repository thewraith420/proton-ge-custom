From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Bob <bob@localhost>
Subject: [PATCH 1/2] ntdll: Enable RSEQ timeslice extension (BobZKernel)

Add BobZKernel RSEQ timeslice extension support to ntdll:

loader.c: opt the process in via prctl(PR_RSEQ_SLICE_EXTENSION,
  PR_RSEQ_SLICE_EXTENSION_SET, PR_RSEQ_SLICE_EXT_ENABLE) at startup.

thread.c: define rseq_abi struct with slice_ctrl field, rseq_get_abi()
  helper using extern ptrdiff_t __rseq_offset (weak), and
  init_thread_rseq_slice() called from start_thread() which sets
  request=1 so every Wine thread participates in slice extensions.

Requires BobZKernel 6.19+ with CONFIG_RSEQ_SLICE_EXTENSION=y.
---
--- a/dlls/ntdll/unix/loader.c
+++ b/dlls/ntdll/unix/loader.c
@@ -54,6 +54,9 @@
 #ifdef HAVE_SYS_RESOURCE_H
 # include <sys/resource.h>
 #endif
+#ifdef __linux__
+# include <sys/prctl.h>
+#endif
 #include <limits.h>
 #ifdef HAVE_SYS_SYSCTL_H
 # include <sys/sysctl.h>
@@ -2382,6 +2385,27 @@
 #endif
 }
 
+/* BobZKernel: Enable RSEQ timeslice extension for this process */
+static void init_rseq_slice_extension(void)
+{
+#ifdef __linux__
+#ifndef PR_RSEQ_SLICE_EXTENSION
+#define PR_RSEQ_SLICE_EXTENSION 79
+#endif
+#ifndef PR_RSEQ_SLICE_EXTENSION_SET
+#define PR_RSEQ_SLICE_EXTENSION_SET 2
+#endif
+#ifndef PR_RSEQ_SLICE_EXT_ENABLE
+#define PR_RSEQ_SLICE_EXT_ENABLE 0x01
+#endif
+    int ret = prctl( PR_RSEQ_SLICE_EXTENSION, PR_RSEQ_SLICE_EXTENSION_SET,
+                     PR_RSEQ_SLICE_EXT_ENABLE, 0, 0 );
+    if (ret == 0)
+        ERR( "RSEQ timeslice extension enabled\n" );
+    else
+        ERR( "RSEQ timeslice extension not available (ret=%d errno=%d)\n", ret, errno );
+#endif
+}
 
 /***********************************************************************
  *           start_main_thread
@@ -2397,6 +2421,7 @@
     hacks_init();
     fsync_init();
     esync_init();
+    init_rseq_slice_extension();
     virtual_map_user_shared_data();
     init_cpu_info();
     init_files();
--- a/dlls/ntdll/unix/thread.c
+++ b/dlls/ntdll/unix/thread.c
@@ -81,6 +81,50 @@
 WINE_DECLARE_DEBUG_CHANNEL(seh);
 WINE_DECLARE_DEBUG_CHANNEL(threadname);
 
+/* BobZKernel: RSEQ timeslice extension - per-thread grant request */
+#ifdef __linux__
+#ifndef __NR_rseq_slice_yield
+#define __NR_rseq_slice_yield 471
+#endif
+
+extern ptrdiff_t __rseq_offset __attribute__((weak));
+
+struct rseq_abi {
+    unsigned int cpu_id_start;
+    unsigned int cpu_id;
+    unsigned long long rseq_cs;
+    unsigned int flags;
+    unsigned int node_id;
+    unsigned int mm_cid;
+    /* Extended fields for BobZKernel RSEQ timeslice */
+    struct {
+        union {
+            unsigned int all;
+            struct {
+                unsigned char request;
+                unsigned char granted;
+                unsigned short __reserved;
+            } bits;
+        } u;
+    } slice_ctrl;
+} __attribute__((aligned(32)));
+
+static struct rseq_abi *rseq_get_abi(void)
+{
+    unsigned long ptr;
+    if (!__rseq_offset) return NULL;
+#if defined(__x86_64__)
+    __asm__ volatile ("mov %%fs:0, %0" : "=r" (ptr));
+    return (struct rseq_abi *)(ptr + __rseq_offset);
+#elif defined(__aarch64__)
+    __asm__ volatile ("mrs %0, tpidr_el0" : "=r" (ptr));
+    return (struct rseq_abi *)(ptr + __rseq_offset);
+#else
+    (void)ptr;
+    return NULL;
+#endif
+}
+#endif /* __linux__ */
 
 pthread_key_t teb_key = 0;
 
@@ -1141,6 +1185,27 @@
  *
  * Startup routine for a newly created thread.
  */
+/* BobZKernel: Request RSEQ timeslice extension for this thread */
+static void init_thread_rseq_slice(void)
+{
+#ifdef __linux__
+    struct rseq_abi *rseq = rseq_get_abi();
+    static int warned_once;
+
+    if (!rseq)
+    {
+        if (!warned_once)
+        {
+            warned_once = 1;
+            ERR( "RSEQ ABI unavailable in thread init (__rseq_offset=%td)\n", __rseq_offset );
+        }
+        return;
+    }
+
+    rseq->slice_ctrl.u.bits.request = 1;
+#endif
+}
+
 static void start_thread( TEB *teb )
 {
     struct ntdll_thread_data *thread_data = (struct ntdll_thread_data *)&teb->GdiTebBatch;
@@ -1148,6 +1213,7 @@
 
     thread_data->pthread_id = pthread_self();
     pthread_setspecific( teb_key, teb );
+    init_thread_rseq_slice();
     server_init_thread( thread_data->start, &suspend );
     signal_start_thread( thread_data->start, thread_data->param, suspend, teb );
 }
