From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Bob <bob@localhost>
Date: Thu, 13 Feb 2026 19:45:00 -0500
Subject: [PATCH] ntdll: Enable RSEQ timeslice extension for game threads

Enable the BobZKernel RSEQ timeslice extension feature for all Wine threads.
Uses proper struct access matching test_grant.c reference implementation.
Includes debug ERR() output to verify initialization.

Requires Linux 6.19+ with RSEQ timeslice extension patches (BobZKernel).
---
 dlls/ntdll/unix/loader.c | 22 ++++++++++++++++++++++
 dlls/ntdll/unix/thread.c | 65 +++++++++++++++++++++++++++++++++++++++++++++++++++++
 2 files changed, 87 insertions(+)

diff --git a/dlls/ntdll/unix/loader.c b/dlls/ntdll/unix/loader.c
index 087ca830251..111111111 100644
--- a/dlls/ntdll/unix/loader.c
+++ b/dlls/ntdll/unix/loader.c
@@ -2388,6 +2388,26 @@ static void hacks_init(void)
 #endif
 }

+/* RSEQ timeslice extension constants (BobZKernel) */
+#ifndef PR_RSEQ_SLICE_EXTENSION
+#define PR_RSEQ_SLICE_EXTENSION         79
+#define PR_RSEQ_SLICE_EXTENSION_SET     2
+#define PR_RSEQ_SLICE_EXT_ENABLE        0x01
+#endif
+
+static void init_rseq_slice_extension(void)
+{
+#ifdef __linux__
+    /* Enable RSEQ timeslice extension for this process (BobZKernel feature).
+     * Silently ignored on kernels without support. */
+    int ret = prctl(PR_RSEQ_SLICE_EXTENSION, PR_RSEQ_SLICE_EXTENSION_SET, PR_RSEQ_SLICE_EXT_ENABLE, 0, 0);
+    if (ret == 0)
+        ERR("RSEQ: Timeslice extension ENABLED for process\n");
+    else
+        ERR("RSEQ: Timeslice extension not available (ret=%d, errno=%d)\n", ret, errno);
+#endif
+}
+
 /***********************************************************************
  *           start_main_thread
  */
@@ -2401,6 +2421,8 @@ static void start_main_thread(void)
     fsync_init();
     esync_init();

+    init_rseq_slice_extension();
+
     virtual_map_user_shared_data();
     init_cpu_info();
     init_files();
diff --git a/dlls/ntdll/unix/thread.c b/dlls/ntdll/unix/thread.c
index 1111111111..2222222222 100644
--- a/dlls/ntdll/unix/thread.c
+++ b/dlls/ntdll/unix/thread.c
@@ -1135,6 +1135,69 @@ static int get_alt_stack_zero_bits( void )
 }


+/* RSEQ structure matching kernel/glibc definition */
+struct rseq_slice_ctrl {
+    union {
+        uint32_t all;
+        struct {
+            uint8_t request;
+            uint8_t granted;
+            uint16_t __reserved;
+        };
+    };
+};
+
+struct rseq_abi {
+    uint32_t cpu_id_start;
+    uint32_t cpu_id;
+    uint64_t rseq_cs;
+    uint32_t flags;
+    uint32_t node_id;
+    uint32_t mm_cid;
+    struct rseq_slice_ctrl slice_ctrl;
+} __attribute__((aligned(32)));
+
+/***********************************************************************
+ *           init_thread_rseq_slice
+ *
+ * Initialize RSEQ timeslice extension for this thread (BobZKernel feature).
+ */
+#ifdef __linux__
+extern ptrdiff_t __rseq_offset __attribute__((weak));
+extern unsigned int __rseq_size __attribute__((weak));
+
+static void init_thread_rseq_slice(void)
+{
+    struct rseq_abi *rseq;
+    char *tp;
+
+#if defined(__x86_64__)
+    __asm__ volatile("mov %%fs:0, %0" : "=r"(tp));
+#elif defined(__aarch64__)
+    __asm__ volatile("mrs %0, tpidr_el0" : "=r"(tp));
+#else
+    ERR("RSEQ: Architecture not supported\n");
+    return;
+#endif
+
+    /* Check if glibc has registered RSEQ */
+    if (__rseq_offset == 0) {
+        static int warned = 0;
+        if (!warned++) ERR("RSEQ: __rseq_offset is 0, glibc RSEQ not registered\n");
+        return;
+    }
+
+    rseq = (struct rseq_abi *)(tp + __rseq_offset);
+
+    /* Set request bit like test_grant.c does */
+    rseq->slice_ctrl.request = 1;
+    __asm__ __volatile__("" ::: "memory");
+
+    ERR("RSEQ: Set request bit for thread (rseq=%p, cpu_id=%u, offset=%ld)\n",
+        rseq, rseq->cpu_id, (long)__rseq_offset);
+}
+#endif
+
 /***********************************************************************
  *           start_thread
  *
@@ -1145,6 +1208,8 @@ static void start_thread( TEB *teb )
     BOOL suspend;

     thread_data->pthread_id = pthread_self();
+#ifdef __linux__
+    init_thread_rseq_slice();
+#endif
     pthread_setspecific( teb_key, teb );
     server_init_thread( thread_data->start, &suspend );
     signal_start_thread( thread_data->start, thread_data->param, suspend, teb );
--
